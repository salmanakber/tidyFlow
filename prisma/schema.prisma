// Working Hours Submission - Allows cleaners to submit their working hours
model WorkingHoursSubmission {
  id          Int       @id @default(autoincrement())
  userId      Int       @map("user_id")
  companyId   Int       @map("company_id")
  date        DateTime // Date for which hours are submitted
  hours       Decimal   @db.Decimal(10, 2) // Hours worked on this date
  description String?   @db.Text // Optional description/notes
  status      String    @default("pending") @map("status") // pending, approved, rejected, paid, locked
  approvedBy  Int?      @map("approved_by")
  approvedAt  DateTime? @map("approved_at")
  lockedAt    DateTime? @map("locked_at")
  lockedBy    Int?      @map("locked_by")
  payrollRecordId Int?  @map("payroll_record_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  user     User                         @relation("WorkingHoursSubmissions", fields: [userId], references: [id], onDelete: Cascade)
  company  Company                      @relation("WorkingHoursSubmissions", fields: [companyId], references: [id], onDelete: Cascade)
  approver User?                        @relation("WorkingHoursApprovals", fields: [approvedBy], references: [id])
  tasks    WorkingHoursSubmissionTask[]

  @@unique([userId, date]) // One submission per user per date
  @@index([userId])
  @@index([companyId])
  @@index([date])
  @@index([status])
  @@map("working_hours_submissions")
}

// Junction table for WorkingHoursSubmission and Task
model WorkingHoursSubmissionTask {
  id                       Int      @id @default(autoincrement())
  workingHoursSubmissionId Int      @map("working_hours_submission_id")
  taskId                   Int      @map("task_id")
  hours                    Decimal? @db.Decimal(10, 2) // Hours allocated to this specific task (optional)
  createdAt                DateTime @default(now()) @map("created_at")

  workingHoursSubmission WorkingHoursSubmission @relation(fields: [workingHoursSubmissionId], references: [id], onDelete: Cascade)
  task                   Task                   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([workingHoursSubmissionId, taskId]) // One task per submission (but multiple tasks per submission)
  @@index([workingHoursSubmissionId])
  @@index([taskId])
  @@map("working_hours_submission_tasks")
}

// Phase 2: Payroll
model PayrollRecord {
  id          Int       @id @default(autoincrement())
  userId      Int       @map("user_id")
  companyId   Int       @map("company_id")
  periodStart DateTime  @map("period_start")
  periodEnd   DateTime  @map("period_end")
  payrollType String    @default("hourly") @map("payroll_type") // "hourly" or "fixed"
  hoursWorked Decimal?  @map("hours_worked") @db.Decimal(10, 2) // Nullable for fixed salary
  hourlyRate  Decimal?  @map("hourly_rate") @db.Decimal(10, 2) // Nullable for fixed salary
  fixedSalary Decimal?  @map("fixed_salary") @db.Decimal(10, 2) // For fixed salary employees
  totalAmount Decimal   @map("total_amount") @db.Decimal(10, 2)
  status      String    @default("pending") // pending, approved, paid
  paidAt      DateTime? @map("paid_at")
  lockedAt    DateTime? @map("locked_at")
  lockedBy    Int?      @map("locked_by")
  paymentExportRef String? @map("payment_export_ref")
  invoiceUrl  String?   @map("invoice_url") // URL to generated invoice PDF
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // HR System Fields
  // Allowances
  hraAllowance        Decimal? @map("hra_allowance") @db.Decimal(10, 2) // House Rent Allowance
  transportAllowance Decimal? @map("transport_allowance") @db.Decimal(10, 2)
  bonus              Decimal? @map("bonus") @db.Decimal(10, 2)
  otherAllowances    Decimal? @map("other_allowances") @db.Decimal(10, 2)
  
  // Overtime
  overtimeHours      Decimal? @map("overtime_hours") @db.Decimal(10, 2)
  overtimeRate        Decimal? @map("overtime_rate") @db.Decimal(10, 2)
  overtimeAmount      Decimal? @map("overtime_amount") @db.Decimal(10, 2)
  
  // Gross Salary (calculated: basic + allowances + overtime + bonuses)
  grossSalary         Decimal? @map("gross_salary") @db.Decimal(10, 2)
  
  // Deductions
  incomeTax           Decimal? @map("income_tax") @db.Decimal(10, 2)
  socialSecurity      Decimal? @map("social_security") @db.Decimal(10, 2)
  insurance           Decimal? @map("insurance") @db.Decimal(10, 2)
  loanRepayment       Decimal? @map("loan_repayment") @db.Decimal(10, 2)
  unpaidLeaveDeduction Decimal? @map("unpaid_leave_deduction") @db.Decimal(10, 2)
  otherDeductions     Decimal? @map("other_deductions") @db.Decimal(10, 2)
  totalDeductions     Decimal? @map("total_deductions") @db.Decimal(10, 2)
  
  // Net Salary (calculated: grossSalary - totalDeductions)
  netSalary           Decimal? @map("net_salary") @db.Decimal(10, 2)
  
  // Payment Details
  paymentDate         DateTime? @map("payment_date")
  bankAccountNumber   String?   @map("bank_account_number") @db.Text
  bankName            String?   @map("bank_name")
  bankSortCode        String?   @map("bank_sort_code")
  paymentMethod       String?   @map("payment_method") // "bank_transfer", "cash", "cheque"
  quickbooksBillId    String?   @map("quickbooks_bill_id")
  quickbooksDocNumber String?   @map("quickbooks_doc_number")
  quickbooksSyncStatus String?  @map("quickbooks_sync_status")
  quickbooksSyncedAt  DateTime? @map("quickbooks_synced_at")
  quickbooksSyncError String?   @map("quickbooks_sync_error") @db.Text

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lineItems PayrollLineItem[]

  @@index([userId])
  @@index([companyId])
  @@index([status])
  @@index([periodStart, periodEnd])
  @@map("payroll_records")
}

// Recurring payroll rules per employee (allowances & deductions with effective dates)
model EmployeePayrollRule {
  id             Int       @id @default(autoincrement())
  userId         Int       @map("user_id")
  companyId      Int       @map("company_id")
  name           String
  type           String    // "allowance" | "deduction"
  amount         Decimal   @db.Decimal(10, 2)
  effectiveStart DateTime  @map("effective_start")
  effectiveEnd   DateTime? @map("effective_end")
  status         String    @default("active") // "active" | "inactive"
  description    String?   @db.Text
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  company   Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  snapshots PayrollLineItem[]

  @@index([userId])
  @@index([companyId])
  @@index([status])
  @@index([effectiveStart, effectiveEnd])
  @@map("employee_payroll_rules")
}

// Snapshot line items on a payroll record (from rules + one-time adjustments)
model PayrollLineItem {
  id              Int      @id @default(autoincrement())
  payrollRecordId Int      @map("payroll_record_id")
  sourceRuleId    Int?     @map("source_rule_id")
  name            String
  type            String   // "allowance" | "deduction"
  amount          Decimal  @db.Decimal(10, 2)
  isRecurring     Boolean  @default(false) @map("is_recurring")
  description     String?  @db.Text
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  payrollRecord PayrollRecord        @relation(fields: [payrollRecordId], references: [id], onDelete: Cascade)
  sourceRule    EmployeePayrollRule? @relation(fields: [sourceRuleId], references: [id], onDelete: SetNull)

  @@index([payrollRecordId])
  @@index([sourceRuleId])
  @@map("payroll_line_items")
}

// Phase 2: Expense tracking
model Expense {
