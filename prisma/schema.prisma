  severity    String    @default("medium") // low, medium, high, critical
  title       String
  message     String    @db.Text
  entityType  String?   @map("entity_type") // user, property, task, client
  entityId    Int?      @map("entity_id")
  metadata    String?   @db.Text // JSON
  dismissedAt DateTime? @map("dismissed_at")
  dismissedBy Int?      @map("dismissed_by")
  createdAt   DateTime  @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([type])
  @@index([severity])
  @@map("ai_insights")
}

// Company AI Configuration (Groq backend control)
model AIConfiguration {
  id                    Int      @id @default(autoincrement())
  companyId             Int      @unique @map("company_id")
  enabled               Boolean  @default(true)
  provider              String   @default("groq")
  model                 String   @default("llama-3.3-70b-versatile")
  visionModel           String   @default("meta-llama/llama-4-scout-17b-16e-instruct") @map("vision_model")
  photoVerification     Boolean  @default(true) @map("photo_verification")
  assignmentRecommend   Boolean  @default(true) @map("assignment_recommend")
  insightsEnabled       Boolean  @default(true) @map("insights_enabled")
  minPhotoScore         Int      @default(60) @map("min_photo_score")
  groqApiKey            String?  @map("groq_api_key") @db.Text
  googleApiKey          String?  @map("google_api_key") @db.Text
  googleModel           String?  @map("google_model")
  googleVisionModel     String?  @map("google_vision_model")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("ai_configurations")
}

// Supply Management
model SupplyItem {
  id           Int      @id @default(autoincrement())
  companyId    Int      @map("company_id")
  name         String
  unit         String   @default("units")
  currentStock Int      @default(0) @map("current_stock")
  minStock     Int      @default(5) @map("min_stock")
  unitCost     Decimal? @map("unit_cost") @db.Decimal(10, 2)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  company Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  usages  SupplyUsage[]

  @@index([companyId])
  @@map("supply_items")
}

model SupplyUsage {
  id           Int      @id @default(autoincrement())
  supplyItemId Int      @map("supply_item_id")
  userId       Int      @map("user_id")
  taskId       Int?     @map("task_id")
  quantity     Int      @default(1)
  notes        String?  @db.Text
  createdAt    DateTime @default(now()) @map("created_at")

  supplyItem SupplyItem @relation(fields: [supplyItemId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  task       Task?      @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([supplyItemId])
  @@index([userId])
  @@index([taskId])
  @@map("supply_usages")
}

// Cleaner requests a duration correction; managers approve into editedDurationMinutes.
model HoursEditRequest {
  id                       Int       @id @default(autoincrement())
  companyId                Int       @map("company_id")
  assignmentId             Int       @map("assignment_id")
  requesterId              Int       @map("requester_id")
  proposedDurationMinutes  Int       @map("proposed_duration_minutes")
  currentDurationMinutes   Int?      @map("current_duration_minutes")
  reason                   String?   @db.Text
  status                   String    @default("pending") // pending, approved, rejected
  reviewedById             Int?      @map("reviewed_by_id")
  reviewedAt               DateTime? @map("reviewed_at")
  reviewNote               String?   @map("review_note") @db.Text
  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime  @updatedAt @map("updated_at")

  company    Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assignment TaskAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  requester  User           @relation("HoursEditRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  reviewer   User?          @relation("HoursEditReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([companyId, status])
  @@index([assignmentId])
  @@index([requesterId])
  @@map("hours_edit_requests")
}

// Client review requests (public vs private flow)
model ReviewRequest {
  id            Int       @id @default(autoincrement())
  taskId        Int       @map("task_id")
  token         String    @unique
  rating        Int?      // 1-5, null until submitted
  comment       String?   @db.Text
  isPublic      Boolean   @default(true) @map("is_public")
  redirectUrl   String?   @map("redirect_url") @db.Text // Google review URL for 4-5 stars
  submittedAt   DateTime? @map("submitted_at")
  expiresAt     DateTime? @map("expires_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([token])
  @@map("review_requests")
}

// Platform subscription tier limits (SaaS admin configurable)
model SubscriptionPlanLimit {
  id                   Int      @id @default(autoincrement())
  tier                 String   @unique // STARTUP, STANDARD, PREMIUM
  label                String   @default("Standard")
  maxCleaners          Int      @default(25) @map("max_cleaners")
  maxProperties        Int      @default(50) @map("max_properties")
  maxManagers          Int      @default(10) @map("max_managers")
  aiRequestsPerMonth   Int      @default(500) @map("ai_requests_per_month")
  aiPhotoAnalysis      Boolean  @default(true) @map("ai_photo_analysis")
  aiInsights           Boolean  @default(true) @map("ai_insights")
  aiAssignment         Boolean  @default(true) @map("ai_assignment")
  aiTaskSuggestions    Boolean  @default(true) @map("ai_task_suggestions")
  aiSupplyForecast     Boolean  @default(false) @map("ai_supply_forecast")
  invoicesEnabled      Boolean  @default(true) @map("invoices_enabled")
  maxInvoicesPerMonth  Int      @default(50) @map("max_invoices_per_month")
  aiInvoiceAssist      Boolean  @default(false) @map("ai_invoice_assist")
  maxPhotoVerificationsPerMonth Int @default(100) @map("max_photo_verifications_per_month")
  maxPdfGenerationsPerMonth     Int @default(50) @map("max_pdf_generations_per_month")
  googleSheetsEnabled           Boolean @default(false) @map("google_sheets_enabled")
  quickbooksEnabled             Boolean @default(false) @map("quickbooks_enabled")
  monthlyPrice                  Decimal @default(55.00) @map("monthly_price") @db.Decimal(10, 2)
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@map("subscription_plan_limits")
}

// Per-company AI activity cache — skip AI when fingerprint unchanged
model AIActivityCache {
  id                  Int      @id @default(autoincrement())
  companyId           Int      @map("company_id")
  feature             String
  scopeKey            String   @map("scope_key")
  activityFingerprint String   @map("activity_fingerprint")
  cachedResult        String?  @db.Text @map("cached_result")
  lastActivityAt      DateTime @default(now()) @map("last_activity_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@unique([companyId, feature, scopeKey], map: "ai_activity_cache_unique")
  @@index([companyId])
  @@map("ai_activity_cache")
}

// Monthly AI usage tracking per company
model AIUsageLog {
  id        Int      @id @default(autoincrement())
  companyId Int      @map("company_id")
  feature   String
  createdAt DateTime @default(now()) @map("created_at")

  @@index([companyId, createdAt])
  @@map("ai_usage_logs")
}

// Client-facing invoices (per task / property)
model ClientInvoice {
  id            Int       @id @default(autoincrement())
  companyId     Int       @map("company_id")
  taskId        Int?      @map("task_id")
  propertyId    Int?      @map("property_id")
  invoiceNumber String    @unique @map("invoice_number")
  clientName    String    @map("client_name")
  clientEmail   String?   @map("client_email")
  clientPhone   String?   @map("client_phone")
  clientAddress String?   @map("client_address") @db.Text
  lineItems     String    @db.Text // JSON array { description, quantity, unitPrice, amount }
  subtotal      Decimal   @db.Decimal(10, 2)
  taxRate       Decimal   @default(0) @map("tax_rate") @db.Decimal(5, 2)
  taxAmount     Decimal   @default(0) @map("tax_amount") @db.Decimal(10, 2)
  totalAmount   Decimal   @map("total_amount") @db.Decimal(10, 2)
  currency      String    @default("GBP")
  status        String    @default("draft") // draft, sent, paid, void
  notes         String?   @db.Text
  pdfUrl        String?   @map("pdf_url") @db.Text
  sentAt        DateTime? @map("sent_at")
  paidAt        DateTime? @map("paid_at")
  dueDate       DateTime? @map("due_date")
  aiGenerated   Boolean   @default(false) @map("ai_generated")
  createdById   Int?      @map("created_by_id")
  quickbooksInvoiceId  String?   @map("quickbooks_invoice_id")
  quickbooksDocNumber  String?   @map("quickbooks_doc_number")
  quickbooksSyncStatus String?   @map("quickbooks_sync_status") // pending, synced, failed
  quickbooksSyncedAt   DateTime? @map("quickbooks_synced_at")
  quickbooksSyncError  String?   @map("quickbooks_sync_error") @db.Text
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  task     Task?     @relation(fields: [taskId], references: [id], onDelete: SetNull)
  property Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  invoiceTasks ClientInvoiceTask[]

  @@index([companyId])
  @@index([taskId])
  @@index([status])
  @@index([quickbooksSyncStatus])
  @@map("client_invoices")
}

// Links multiple completed tasks to one period/client invoice.
model ClientInvoiceTask {
  id        Int @id @default(autoincrement())
  invoiceId Int @map("invoice_id")
  taskId    Int @map("task_id")

  invoice ClientInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  task    Task          @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([invoiceId, taskId])
  @@index([taskId])
  @@map("client_invoice_tasks")
}

// Per-company invoice branding, numbering, and tax rules
model CompanyInvoiceSettings {
  id                    Int      @id @default(autoincrement())
  companyId             Int      @unique @map("company_id")
  companyDisplayName    String?  @map("company_display_name")
  logoUrl               String?  @map("logo_url") @db.Text
  address               String?  @db.Text
  phone                 String?
  email                 String?
  website               String?
  taxRegistrationNumber String?  @map("tax_registration_number")
  invoicePrefix         String   @default("INV-") @map("invoice_prefix")
  nextInvoiceNumber     Int      @default(1) @map("next_invoice_number")
  taxEnabled            Boolean  @default(false) @map("tax_enabled")
  taxRules              String   @default("[]") @map("tax_rules") @db.Text // JSON TaxRule[]
  defaultTaxRuleId      String?  @map("default_tax_rule_id")
  payrollPrefix         String   @default("PAY-") @map("payroll_prefix")
  nextPayrollNumber     Int      @default(1) @map("next_payroll_number")
  payrollTaxEnabled     Boolean  @default(false) @map("payroll_tax_enabled")
  payrollTaxRules       String   @default("[]") @map("payroll_tax_rules") @db.Text
  payrollDefaultTaxRuleId String? @map("payroll_default_tax_rule_id")
  invoiceLanguage       String   @default("en") @map("invoice_language")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("company_invoice_settings")
}

// One Google Sheet connection per company (master data source)
model CompanyGoogleSheet {
  id                Int       @id @default(autoincrement())
  companyId         Int       @unique @map("company_id")
  spreadsheetId     String    @map("spreadsheet_id")
  spreadsheetUrl    String    @map("spreadsheet_url") @db.Text
  spreadsheetTitle  String?   @map("spreadsheet_title")
  propertiesTab     String    @default("Properties") @map("properties_tab")
  tasksTab          String    @default("Tasks") @map("tasks_tab")
  propertiesMapping String?   @map("properties_mapping") @db.Text // JSON column map
  tasksMapping      String?   @map("tasks_mapping") @db.Text // JSON { columnMapping, propertyIdColumn, actionColumn }
  propertyIdColumn  String?   @map("property_id_column")
  actionColumn      String?   @map("action_column")
  uniqueColumn      String?   @map("unique_column")
  watchChannelId    String?   @map("watch_channel_id")
  watchResourceId   String?   @map("watch_resource_id")
  watchExpiration   DateTime? @map("watch_expiration")
  syncEnabled       Boolean   @default(true) @map("sync_enabled")
  lastSyncedAt      DateTime? @map("last_synced_at")
  lastSyncError     String?   @map("last_sync_error") @db.Text
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([spreadsheetId])
  @@map("company_google_sheets")
}

// QuickBooks Online OAuth connection (one per company)
model QuickBooksConnection {
  id              Int       @id @default(autoincrement())
  companyId       Int       @unique @map("company_id")
  realmId         String    @map("realm_id")
  accessTokenEnc  String    @map("access_token_enc") @db.Text
  refreshTokenEnc String    @map("refresh_token_enc") @db.Text
  accessTokenExp  DateTime  @map("access_token_exp")
  refreshTokenExp DateTime? @map("refresh_token_exp")
  qbCompanyName   String?   @map("qb_company_name")
  autoSyncOnSend  Boolean   @default(true) @map("auto_sync_on_send")
  autoSyncOnPaid  Boolean   @default(true) @map("auto_sync_on_paid")
  autoSyncOnPayroll Boolean @default(true) @map("auto_sync_on_payroll")
  connectedById   Int?      @map("connected_by_id")
  connectedAt     DateTime  @default(now()) @map("connected_at")
  lastSyncAt      DateTime? @map("last_sync_at")
  invoicesSynced  Int       @default(0) @map("invoices_synced")
  payrollSynced   Int       @default(0) @map("payroll_synced")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("quickbooks_connections")
}

model QuickBooksCustomerMap {
  id                   Int    @id @default(autoincrement())
  companyId            Int    @map("company_id")
  clientName           String @map("client_name")
  clientEmail          String? @map("client_email")
  quickbooksCustomerId String @map("quickbooks_customer_id")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, clientName, clientEmail])
  @@index([companyId])
  @@map("quickbooks_customer_maps")
}

model QuickBooksSyncLog {
  id        Int      @id @default(autoincrement())
  companyId Int      @map("company_id")
  invoiceId Int?     @map("invoice_id")
  payrollRecordId Int? @map("payroll_record_id")
  action    String   // sync_invoice, sync_payroll, mark_paid, disconnect
  status    String   // success, failed
  message   String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt])
  @@map("quickbooks_sync_logs")
}

model QuickBooksVendorMap {
  id                 Int    @id @default(autoincrement())
  companyId          Int    @map("company_id")
  userId             Int    @map("user_id")
  vendorName         String @map("vendor_name")
  quickbooksVendorId String @map("quickbooks_vendor_id")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
  @@index([companyId])
  @@map("quickbooks_vendor_maps")
}
