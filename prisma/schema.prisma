// System Settings model for admin configuration
model SystemSetting {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  value       String   @db.Text
  category    String // "stripe", "billing", "email", "google_maps", "app", "general"
  description String?  @db.Text
  isEncrypted Boolean  @default(false) @map("is_encrypted") // For sensitive data like API keys
  updatedBy   Int?     @map("updated_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  updatedByUser User? @relation(fields: [updatedBy], references: [id])

  @@index([category])
  @@index([key])
  @@map("system_settings")
}

// Permission model for granular admin access control
model Permission {
  id          Int      @id @default(autoincrement())
  key         String   @unique // e.g., "users.create", "billing.view", "settings.edit"
  name        String   // Human-readable name
  description String?  @db.Text
  category    String   // e.g., "users", "billing", "settings", "companies"
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  adminPermissions AdminPermission[]

  @@index([category])
  @@index([key])
  @@map("permissions")
}

// Many-to-many: Admin users and their permissions
model AdminPermission {
  id           Int       @id @default(autoincrement())
  userId       Int       @map("user_id")
  permissionId Int       @map("permission_id")
  grantedBy    Int?      @map("granted_by") // Who granted this permission
  grantedAt    DateTime  @default(now()) @map("granted_at")
  revokedAt    DateTime? @map("revoked_at")
  isActive     Boolean   @default(true) @map("is_active")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  granter    User?      @relation("PermissionGrants", fields: [grantedBy], references: [id])

  @@unique([userId, permissionId])
  @@index([userId])
  @@index([permissionId])
  @@index([isActive])
  @@map("admin_permissions")
}

