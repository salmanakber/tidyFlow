{
  "name": "mayaops-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx server.ts",
    "build": "next build",
    "postbuild": "mkdir -p .next/server/assets/fonts && cp -R assets/fonts/. .next/server/assets/fonts/",
    "start": "NODE_ENV=production tsx server.ts",
    "lint": "next lint",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:seed": "tsx prisma/seed.ts",
    "db:setup": "prisma migrate dev && prisma db seed",
    "worker": "tsx workers/recurring-jobs-worker.ts",
    "worker:build": "tsc workers/recurring-jobs-worker.ts --outDir workers --module commonjs --target es2020 --esModuleInterop",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:restart": "pm2 restart ecosystem.config.js",
    "pm2:logs": "pm2 logs",
    "pm2:monit": "pm2 monit"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-ses": "^3.958.0",
    "@aws-sdk/credential-providers": "^3.958.0",
