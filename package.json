    "@fontsource/noto-sans-sc": "^5.2.9",
    "@getbrevo/brevo": "^1.0.0",
    "@prisma/client": "^5.7.1",
    "@sendgrid/mail": "^8.1.6",
    "@types/node-cron": "^3.0.5",
    "@types/pdfkit": "^0.17.4",
    "arabic-persian-reshaper": "^1.0.1",
    "autoprefixer": "^10.4.16",
    "aws-sdk": "^2.1520.0",
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.69.4",
    "cloudinary": "^2.8.0",
    "cron": "^4.4.0",
    "exifr": "^7.1.3",
    "expo-server-sdk": "^4.0.0",
    "firebase-admin": "^13.6.0",
    "googleapis": "^129.0.0",
    "imapflow": "^1.4.7",
    "ioredis": "^5.9.3",
