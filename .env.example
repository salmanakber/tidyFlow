# Database
DATABASE_URL=postgresql://user:password@localhost:5432/tidyflow

# Auth
JWT_SECRET=change-me

# Server (VPS — use 3060 if 3000 is already taken)
PORT=3060

# Domains (production)
NEXT_PUBLIC_APP_URL=https://app.tidyflowapp.com
NEXT_PUBLIC_API_URL=https://api.tidyflowapp.com
NEXT_PUBLIC_WEB_URL=https://tidyflowapp.com

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Optional: protect public pricing write endpoints (POST/PATCH/DELETE) for website CMS sync
PRICING_WEBSITE_API_KEY=

# Email
EMAIL_FROM=noreply@tidyflowapp.com

# Redis / cron
REDIS_URL=redis://localhost:6379
CRON_SECRET=
CRON_BASE_URL=https://api.tidyflowapp.com
